# ESP-IDF build output
/build/

# Fetched by the component manager from main/idf_component.yml + dependencies.lock
/managed_components/

# Generated by menuconfig — contains local WiFi credentials; use sdkconfig.defaults instead
/sdkconfig
/sdkconfig.old

# IDF / clangd tooling
/.clangd

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Server runtime data
server/captures/
server/data/*.db
server/data/captures/

# YOLO weights (downloaded by Ultralytics at build/runtime)
*.pt

# Environment and secrets
.env
.env.*
!.env.example

# macOS / Windows
.DS_Store
Thumbs.db

# Editors (machine-specific paths and session state)
.vscode/
.idea/
*.swp
*.swo
*~

# Local Docker overrides
docker-compose.override.yml
